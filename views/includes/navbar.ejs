<nav class="navbar navbar-expand-md bg-body-light border-bottom sticky-top">
  <div class="container-fluid">
    <a class="navbar-brand" href="/listings"><i class="fa-solid fa-compass"></i> Wanderlust</a>
    
    <div class="navbar-nav ms-auto search-container">
      <form class="d-flex search-pill" role="search" action="/listings" method="GET">
        <input
          class="form-control search-input"
          type="search"
          placeholder="Search destinations"
          name="search"
        />
        <button class="btn btn-search-icon" type="submit">
          <i class="fa-solid fa-magnifying-glass"></i>
        </button>
      </form>
    </div>

    <div class="navbar-nav ms-auto profile-menu-container d-flex flex-row align-items-center">
      <!-- Notification Bell -->
      <% if (currUser) { %>
        <div class="nav-link position-relative me-3" id="notifBtn" style="cursor: pointer;">
          <i class="fa-solid fa-bell fs-5 text-dark"></i>
          <span class="position-absolute translate-middle badge rounded-pill bg-danger d-none" id="notifBadge" style="top: 10px; right: -12px;">
            0
          </span>
          <div class="notification-dropdown shadow-lg d-none" id="notifDropdown">
            <div class="p-3 border-bottom d-flex justify-content-between align-items-center">
              <span class="fw-bold">Notifications</span>
              <button class="btn btn-sm text-primary p-0 xsmall" id="markAllRead">Clear All</button>
            </div>
            <div id="notifList" class="notif-scroll">
              <!-- Notifs will appear here -->
              <div class="p-4 text-center text-muted small">No new notifications</div>
            </div>
          </div>
        </div>
      <% } %>
      
      <% if (currUser && currUser.role === 'admin') { %>
        <a href="/dashboard/admin" class="nav-link fw-bold p-2 px-3 rounded-pill me-2 text-white shadow-sm" style="background: linear-gradient(135deg, #222222 0%, #444444 100%); cursor:pointer; text-decoration: none; transition: 0.2s;"><i class="fa-solid fa-shield-halved me-1"></i> Admin Console</a>
      <% } %>

      <% if (currUser && currUser.role === 'host') { %>
        <a href="/dashboard/host" class="nav-link fw-bold p-2 px-3 rounded-pill me-2 text-white shadow-sm" style="background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%); cursor:pointer; text-decoration: none; transition: 0.2s;"><i class="fa-solid fa-chart-line me-1"></i> Host Console</a>
      <% } %>

      <% if (!currUser || (currUser.role !== 'admin' && currUser.role !== 'host')) { %>
        <a href="/roommates" class="nav-link fw-bold p-2 px-3 rounded-pill me-2" style="background-color: #f7f7f7; color: #ff385c; cursor:pointer; text-decoration: none; transition: 0.2s;">Find Roommates</a>
      <% } %>
      <a class="nav-link profile-menu-btn" href="#" id="navbarDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
        <i class="fa-solid fa-bars"></i>
        <i class="fa-solid fa-user-circle"></i>
      </a>
      <ul class="dropdown-menu dropdown-menu-end shadow border-0" aria-labelledby="navbarDropdown">
        <% if (!currUser) { %>
          <li><a class="dropdown-item fw-semibold" href="/signup">Sign up</a></li>
          <li><a class="dropdown-item" href="/login">Log in</a></li>
        <% } else { %>
          <% if (currUser.role === 'admin') { %>
            <li><a class="dropdown-item fw-bold text-danger border-bottom pb-2 mb-2" href="/dashboard/admin"><i class="fa-solid fa-shield-halved me-2"></i> Admin Console</a></li>
          <% } else if (currUser.role === 'host') { %>
            <li><a class="dropdown-item fw-bold text-primary" href="/dashboard/host"><i class="fa-solid fa-chart-line me-2"></i> Host Dashboard</a></li>
          <% } else if (currUser.role === 'user') { %>
            <li><a class="dropdown-item fw-bold text-dark border-bottom pb-2 mb-2" href="/dashboard/user"><i class="fa-solid fa-gauge me-2"></i> My Dashboard</a></li>
            <% if (typeof activeTrip !== 'undefined' && activeTrip) { %>
              <li><a class="dropdown-item fw-bold text-primary" href="/dashboard/trip/<%= activeTrip._id %>"><i class="fa-solid fa-map-location-dot me-2"></i> Trip Dashboard</a></li>
            <% } %>
            <li><a class="dropdown-item fw-bold text-indigo" href="/dashboard/user/ai-suggestions" style="color: #6366f1;"><i class="fa-solid fa-wand-magic-sparkles me-2"></i> Ask AI for Stays</a></li>
          <% } %>

          <% if (currUser.role === 'user') { %>
            <li><a class="dropdown-item fw-semibold text-dark" href="/bookings">My Trips 🎒</a></li>
            <li><a class="dropdown-item fw-semibold text-dark" href="/wishlist">Wishlist ❤️</a></li>
            <li><a class="dropdown-item" href="/roommates">Roommates 🌍</a></li>
            <li><hr class="dropdown-divider"></li>
            <li><a class="dropdown-item" href="/listings/new">Airbnb your home</a></li>
          <% } %>
          
          <li><hr class="dropdown-divider"></li>
          <li><a class="dropdown-item" href="/logout">Log out</a></li>
        <% } %>
      </ul>
    </div>
  </div>
</nav>