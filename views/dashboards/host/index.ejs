<% layout("layouts/dashboard") %>

<div class="row g-4 mb-4">
    <!-- Stat Cards -->
    <div class="col-md-3">
        <div class="card border-0 shadow-sm rounded-4 p-4 text-center bg-dark text-white h-100">
            <h1 class="display-5 fw-bold mb-0 text-start text-emerald"><%= activeListingsCount %></h1>
            <p class="text-white-50 fw-bold mb-0 text-start small">Active Properties</p>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm rounded-4 p-4 h-100" style="background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%); color:white;">
            <h1 class="display-5 fw-bold mb-0 text-start">₹<%= totalEarnings.toLocaleString("en-IN") %></h1>
            <p class="text-white-50 fw-bold mb-0 text-start small">Total Net Revenue</p>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm rounded-4 p-4 h-100 bg-white">
            <h1 class="display-5 fw-bold mb-0 text-start text-primary"><%= occupancyRate %>%</h1>
            <p class="text-muted fw-bold mb-0 text-start small">Avg. Occupancy Rate</p>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm rounded-4 p-4 h-100 bg-warning bg-opacity-10">
            <h1 class="display-5 fw-bold mb-0 text-start text-warning"><%= pendingBookings %></h1>
            <p class="text-warning fw-bold mb-0 text-start small">Pending Requests</p>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <!-- Revenue Chart -->
    <div class="col-md-8">
        <div class="card border-0 shadow-sm rounded-4 p-4 bg-white">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h5 class="fw-bold mb-0">Revenue Analytics</h5>
                <select class="form-select form-select-sm w-auto rounded-pill border-0 bg-light px-3">
                    <option>Last 6 Months</option>
                    <option>Last Year</option>
                </select>
            </div>
            <canvas id="hostRevenueChart" style="max-height: 300px;"></canvas>
        </div>
    </div>

    <!-- Quick Actions & Visibility -->
    <div class="col-md-4">
        <div class="card border-0 shadow-sm rounded-4 p-4 bg-white mb-4">
            <h6 class="fw-bold text-muted text-uppercase small mb-4">Quick Glimpse</h6>
            <div class="d-flex align-items-center mb-4">
                <div class="bg-primary bg-opacity-10 text-primary rounded-circle p-3 me-3"><i class="fa-solid fa-users fs-4"></i></div>
                <div>
                    <h6 class="fw-bold mb-0"><%= totalBookings %></h6>
                    <small class="text-muted">Total stays managed</small>
                </div>
            </div>
            <div class="d-flex align-items-center mb-0">
                <div class="bg-success bg-opacity-10 text-success rounded-circle p-3 me-3"><i class="fa-solid fa-wallet fs-4"></i></div>
                <div>
                    <h6 class="fw-bold mb-0">₹<%= monthlyEarnings.toLocaleString("en-IN") %></h6>
                    <small class="text-muted">Revenue this month</small>
                </div>
            </div>
        </div>

        <div class="card border-0 shadow-sm rounded-4 p-4 text-white overflow-hidden" style="background: #1e293b;">
            <h5 class="fw-bold mb-3">Maximize Returns</h5>
            <p class="small text-white-50 mb-4">Properties with "Instant Book" enabled see 30% higher conversion rates.</p>
            <a href="/dashboard/host/pricing" class="btn btn-emerald w-100 rounded-pill fw-bold py-2 shadow-sm border-0">Upgrade Pricing Rules</a>
            <i class="fa-solid fa-bolt position-absolute bottom-0 end-0 m-3 fs-1 opacity-10"></i>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    const ctx = document.getElementById('hostRevenueChart').getContext('2d');
    new Chart(ctx, {
        type: 'line',
        data: {
            labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun'],
            datasets: [{
                label: 'Revenue (₹)',
                data: [12000, 19000, 15000, 25000, 22000, 30000],
                borderColor: '#4f46e5',
                backgroundColor: 'rgba(79, 70, 229, 0.1)',
                fill: true,
                tension: 0.4,
                borderWidth: 3,
                pointRadius: 4,
                pointBackgroundColor: '#fff',
                pointBorderWidth: 2
            }]
        },
        options: {
            plugins: { legend: { display: false } },
            scales: {
                y: { grid: { display: true, color: '#f1f5f9' }, border: { display: false }, ticks: { callback: v => '₹' + v/1000 + 'k' } },
                x: { grid: { display: false }, border: { display: false } }
            },
            maintainAspectRatio: false
        }
    });
</script>

<style>
    .text-emerald { color: #10b981 !important; }
    .btn-emerald { background-color: #10b981 !important; color: white !important; }
</style>
