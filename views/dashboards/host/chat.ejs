<% layout("layouts/dashboard") %>

<div class="row g-4 h-100 mb-5">
    <!-- Chat Sidebar / Recent Conversations -->
    <div class="col-md-4">
        <div class="card border-0 shadow-sm rounded-4 h-100 bg-white">
            <div class="p-4 border-bottom">
                <div class="d-flex justify-content-between align-items-center mb-0">
                    <h5 class="fw-bold mb-0">Guest Concierge</h5>
                    <div class="bg-primary bg-opacity-10 text-primary rounded-circle p-2 shadow-sm"><i class="fa-solid fa-message"></i></div>
                </div>
            </div>
            
            <div class="p-3">
                <input type="text" class="form-control rounded-pill bg-light border-0 py-2 px-3 xsmall shadow-none" placeholder="Search guests...">
            </div>

            <div class="overflow-auto pe-1" style="max-height: 500px;">
                <!-- Inquiry Chat Mock -->
                <div class="p-3 border-bottom d-flex align-items-center bg-indigo bg-opacity-5 position-relative border-start border-4 border-primary">
                    <div class="bg-indigo text-white rounded-circle me-3 flex-shrink-0 d-flex align-items-center justify-content-center fw-bold xsmall shadow-sm" style="width: 44px; height: 44px; background: #6366f1;">R</div>
                    <div class="flex-fill">
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <h6 class="fw-bold mb-0 xsmall">Rohan (Pre-booking)</h6>
                            <span class="xsmall text-muted fw-bold small">09:15 AM</span>
                        </div>
                        <p class="text-truncate xsmall mb-0 text-dark fw-bold">Does the room have Wi-Fi speed above 100 Mbps?</p>
                    </div>
                </div>
                <!-- Check-in Chat Mock -->
                <div class="p-3 border-bottom d-flex align-items-center opacity-75">
                    <div class="bg-dark rounded-circle me-3 flex-shrink-0 d-flex align-items-center justify-content-center text-white fw-bold xsmall shadow-sm" style="width: 44px; height: 44px;">A</div>
                    <div class="flex-fill">
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <h6 class="fw-bold mb-0 xsmall">Ananya (Check-in)</h6>
                            <span class="xsmall text-muted fw-bold small">Yesterday</span>
                        </div>
                        <p class="text-truncate xsmall mb-0 text-muted">I've arrived at the gate. Where should I pick up the keys?</p>
                    </div>
                </div>
                <!-- Other Guest Chats -->
                <div class="p-4 text-center text-muted">
                    <i class="fa-solid fa-inbox fs-1 opacity-10 mb-2"></i>
                    <p class="xsmall mb-0">No more active conversations.</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Active Chat Window -->
    <div class="col-md-8">
        <div class="card border-0 shadow-sm rounded-4 h-100 flex-column bg-white overflow-hidden">
            <!-- Header -->
            <div class="p-4 border-bottom d-flex align-items-center justify-content-between bg-white position-sticky top-0 z-2 shadow-sm">
                <div class="d-flex align-items-center">
                    <div class="bg-indigo text-white rounded-circle me-3 d-flex align-items-center justify-content-center fw-bold xsmall shadow-sm" style="width: 40px; height: 40px; background: #6366f1;">R</div>
                    <div>
                        <h6 class="fw-bold mb-0">Rohan</h6>
                        <small class="text-success xsmall fw-bold"><i class="fa-solid fa-circle me-1 fa-2xs"></i> Inquiring about Goa Villa</small>
                    </div>
                </div>
                <div class="d-flex gap-3 text-muted">
                    <i class="fa-solid fa-circle-question"></i>
                    <i class="fa-solid fa-user-shield"></i>
                </div>
            </div>

            <!-- Messages Area -->
            <div class="p-4 flex-fill overflow-auto bg-light bg-opacity-25" style="height: 400px;">
                <div class="text-center mb-4"><span class="badge bg-light text-muted fw-bold xsmall rounded-pill border">10 Oct 2024</span></div>
                
                <div class="d-flex mb-4 gap-3 align-items-end">
                    <div class="bg-indigo rounded-circle shadow-sm" style="width: 28px; height: 28px; background: #6366f1;"></div>
                    <div class="bg-white p-3 rounded-4 shadow-sm xsmall border" style="max-width: 70%; border-bottom-left-radius: 4px !important;">
                        Hi! I'm planning a workation and your villa looks perfect. Just wanted to double check if the Wi-Fi is reliable and fast enough for zoom calls?
                    </div>
                </div>

                <div class="d-flex mb-4 gap-3 align-items-end flex-row-reverse">
                    <div class="bg-dark p-3 rounded-4 shadow-sm xsmall text-white" style="max-width: 70%; border-bottom-right-radius: 4px !important;">
                        Hello Rohan! Yes, we have a dedicated fiber-optic line with speeds up to 200 Mbps. I work from there often myself!
                    </div>
                </div>
                
                <div class="d-flex mb-4 gap-3 align-items-end">
                    <div class="bg-indigo rounded-circle shadow-sm" style="width: 28px; height: 28px; background: #6366f1;"></div>
                    <div class="bg-white p-3 rounded-4 shadow-sm xsmall border" style="max-width: 70%; border-bottom-left-radius: 4px !important;">
                        That sounds perfect! Does the room have a dedicated desk and chair as well?
                    </div>
                </div>
            </div>

            <!-- Input Area -->
            <div class="p-4 border-top bg-white">
                <div class="d-flex gap-3 align-items-center">
                    <div class="text-muted"><i class="fa-solid fa-circle-plus fs-4"></i></div>
                    <input type="text" class="form-control rounded-pill border-0 py-3 bg-light shadow-none xsmall px-4" placeholder="Answer guest's question here...">
                    <div class="bg-primary text-white rounded-circle p-2 shadow-sm" style="width: 44px; height: 44px; display: flex; align-items: center; justify-content: center; background: #4f46e5 !important;"><i class="fa-solid fa-paper-plane"></i></div>
                </div>
            </div>
        </div>
    </div>
</div>
