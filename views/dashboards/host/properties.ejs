<% layout("layouts/dashboard") %>

<div class="row g-4 mb-4">
    <div class="col-12 d-flex justify-content-between align-items-center">
        <h4 class="fw-bold mb-0">Your Rental Portfolio</h4>
        <a href="/listings/new" class="btn btn-primary rounded-pill px-4 fw-bold border-0 shadow-sm" style="background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%);"><i class="fa-solid fa-plus me-2"></i> List New Property</a>
    </div>

    <% myListings.forEach(listing => { %>
    <div class="col-md-6 col-lg-4">
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden h-100 bg-white overlay-hover">
            <div class="position-relative">
                <img src="<%= listing.image.url %>" class="card-img-top" style="height: 200px; object-fit: cover;">
                <div class="position-absolute top-0 end-0 m-3">
                    <span class="badge rounded-pill px-3 py-2 <%= listing.status === 'approved' ? 'bg-success' : (listing.status === 'pending' ? 'bg-warning text-dark' : 'bg-danger') %>">
                        <%= listing.status.charAt(0).toUpperCase() + listing.status.slice(1) %>
                    </span>
                </div>
            </div>
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-start mb-2">
                    <h5 class="fw-bold mb-0 text-truncate" style="max-width: 200px;"><%= listing.title %></h5>
                </div>
                <p class="text-muted small mb-4"><i class="fa-solid fa-location-dot me-1"></i> <%= listing.location %>, <%= listing.country %></p>
                
                <div class="row g-2 mb-4">
                    <div class="col-4">
                        <div class="bg-light rounded-3 p-2 text-center">
                            <p class="text-muted xsmall mb-0 text-uppercase">PRICE</p>
                            <p class="fw-bold mb-0 small">₹<%= listing.price %></p>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="bg-light rounded-3 p-2 text-center">
                            <p class="text-muted xsmall mb-0 text-uppercase">REVIEWS</p>
                            <p class="fw-bold mb-0 small"><%= listing.reviews.length %></p>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="bg-light rounded-3 p-2 text-center">
                            <p class="text-muted xsmall mb-0 text-uppercase">RATING</p>
                            <p class="fw-bold mb-0 small text-warning">★ 4.8</p>
                        </div>
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <a href="/listings/<%= listing._id %>/edit" class="btn btn-outline-dark btn-sm flex-fill rounded-pill py-2 fw-bold"><i class="fa-solid fa-pen-to-square me-1"></i> Edit Details</a>
                    <a href="/dashboard/host/pricing" class="btn btn-outline-primary btn-sm flex-fill rounded-pill py-2 fw-bold"><i class="fa-solid fa-calendar-days me-1"></i> Pricing</a>
                </div>
            </div>
        </div>
    </div>
    <% }) %>

    <% if(myListings.length === 0) { %>
        <div class="col-12 text-center py-5">
            <div class="bg-light d-inline-flex p-4 rounded-circle mb-4">
                <i class="fa-solid fa-house-chimney-user fs-1 text-muted opacity-50"></i>
            </div>
            <h4 class="fw-bold text-muted">No properties listed yet!</h4>
            <p class="text-muted small mb-4">Start earning by listing your first property on WanderLust.</p>
            <a href="/listings/new" class="btn btn-primary rounded-pill px-5 py-3 fw-bold border-0" style="background: #4f46e5;">List First Property</a>
        </div>
    <% } %>
</div>
