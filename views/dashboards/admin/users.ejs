<% layout("layouts/dashboard") %>
<div class="card border-0 shadow-sm rounded-4 p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h5 class="fw-bold mb-0">Manage Users</h5>
        <div class="input-group w-auto">
            <input type="text" class="form-control rounded-start-pill bg-light border-0" placeholder="Search by email...">
            <button class="btn btn-light rounded-end-pill"><i class="fa-solid fa-search"></i></button>
        </div>
    </div>
    
    <div class="table-responsive">
        <table class="table table-hover align-middle flex-grow-1">
            <thead class="table-light">
                <tr>
                    <th>User / Email</th>
                    <th>Role</th>
                    <th>Verification</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <% if(typeof users !== 'undefined' && users.length > 0) { %>
                    <% for(let user of users) { %>
                    <tr>
                        <td>
                            <div class="d-flex align-items-center">
                                <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center me-3 text-uppercase" style="width:40px;height:40px;"><%= user.email.charAt(0) %></div>
                                <span class="fw-bold"><%= user.email %></span>
                            </div>
                        </td>
                        <td>
                            <% if(user.role === 'admin') { %>
                                <span class="badge bg-danger bg-opacity-10 text-danger rounded-pill">Admin</span>
                            <% } else if(user.role === 'host') { %>
                                <span class="badge bg-dark bg-opacity-10 text-dark rounded-pill">Host</span>
                            <% } else { %>
                                <span class="badge bg-light text-dark border border-secondary rounded-pill">User</span>
                            <% } %>
                        </td>
                        <td>
                            <% if(user.profile && user.profile.verificationStatus === 'verified') { %>
                                <span class="badge bg-success bg-opacity-10 text-success rounded-pill"><i class="fa-solid fa-check"></i> Verified</span>
                            <% } else if(user.profile && user.profile.verificationStatus === 'pending') { %>
                                <span class="badge bg-warning bg-opacity-10 text-warning rounded-pill"><i class="fa-solid fa-clock"></i> Pending ID</span>
                            <% } else { %>
                                <span class="badge bg-light text-muted rounded-pill"><i class="fa-solid fa-minus"></i> Unverified</span>
                            <% } %>
                        </td>
                        <td>
                            <% if(user.isBlocked) { %>
                                <span class="text-danger"><i class="fa-solid fa-ban fa-2xs"></i> Suspended</span>
                            <% } else { %>
                                <span class="text-success"><i class="fa-solid fa-circle fa-2xs"></i> Active</span>
                            <% } %>
                        </td>
                        <td>
                            <div class="d-flex gap-2">
                                <form action="/dashboard/admin/users/<%= user._id %>/verify" method="POST">
                                    <button class="btn btn-sm btn-outline-success rounded-pill px-3">Verify</button>
                                </form>
                                <form action="/dashboard/admin/users/<%= user._id %>/block" method="POST">
                                    <button class="btn btn-sm <%= user.isBlocked ? 'btn-danger' : 'btn-outline-danger' %> rounded-pill px-3">
                                        <%= user.isBlocked ? 'Unblock' : 'Block' %>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                    <% } %>
                <% } else { %>
                    <tr><td colspan="5" class="text-center py-4 text-muted">No users found.</td></tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>
