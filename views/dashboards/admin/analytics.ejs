<% layout("layouts/dashboard") %>
<div class="row g-4">
    <div class="col-md-8">
        <div class="card border-0 shadow-sm rounded-4 p-4 h-100">
            <h5 class="fw-bold mb-4">Revenue & Bookings Trend</h5>
            <div class="d-flex align-items-end justify-content-between px-3 pb-3 border-bottom" style="height: 350px;">
                <div class="bg-dark rounded-top" style="width: 50px; height: 10%;"><div style="background:#fe424d; height: 50%; width: 100%; position:absolute; bottom:0; opacity:0.5;"></div></div>
                <div class="bg-dark rounded-top" style="width: 50px; height: 15%;"></div>
                <div class="bg-dark rounded-top" style="width: 50px; height: 35%;"></div>
                <div class="bg-dark rounded-top" style="width: 50px; height: 40%;"></div>
                <div class="bg-dark rounded-top" style="width: 50px; height: 80%;"></div>
                <div class="bg-dark rounded-top" style="width: 50px; height: 100%;"></div>
                <div class="bg-dark rounded-top" style="width: 50px; height: 75%;"></div>
            </div>
            <div class="d-flex justify-content-between px-3 mt-2 text-muted small fw-bold">
                <span>Jan</span><span>Feb</span><span>Mar</span><span>Apr</span><span>May</span><span class="text-dark">Jun</span><span>Jul</span>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm rounded-4 p-4 mb-4">
            <h6 class="fw-bold mb-3">Top Cities</h6>
            <div class="d-flex justify-content-between mb-2"><span class="fw-bold text-muted">1. Goa</span> <span class="fw-bold">45%</span></div>
            <div class="d-flex justify-content-between mb-2"><span class="fw-bold text-muted">2. Mumbai</span> <span class="fw-bold">25%</span></div>
            <div class="d-flex justify-content-between mb-2"><span class="fw-bold text-muted">3. Bali</span> <span class="fw-bold">15%</span></div>
            <div class="d-flex justify-content-between"><span class="fw-bold text-muted">4. Delhi</span> <span class="fw-bold">10%</span></div>
        </div>
        <div class="card border-0 shadow-sm rounded-4 p-4 text-center text-white" style="background:#fe424d;">
            <i class="fa-solid fa-arrow-trend-up fs-1 mb-2"></i>
            <h3 class="fw-bold mb-0">+35%</h3>
            <p class="mb-0 fw-bold opacity-75">Growth this month</p>
        </div>
    </div>
</div>
