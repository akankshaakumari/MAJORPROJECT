<% layout("layouts/dashboard") %>

<div class="row g-4 mb-5">
    <div class="col-md-12">
        <div class="d-flex align-items-center mb-4">
            <div class="bg-primary bg-opacity-10 text-primary rounded-circle p-2 me-3"><i class="fa-solid fa-route fs-5"></i></div>
            <h5 class="fw-bold mb-0">Daily Expedition Planner <span class="badge bg-light text-muted rounded-pill xsmall ms-2"><%= trip.planner.length %> Stages Planned</span></h5>
        </div>
        
        <div class="row g-4 mb-4">
            <div class="col-md-12">
                <div class="card border-0 shadow-sm rounded-4 p-4 p-md-5 bg-white">
                    <div class="d-flex justify-content-between align-items-center mb-5">
                       <h6 class="fw-800 text-dark mb-0">Itinerary Timeline</h6>
                       <button class="btn btn-primary rounded-pill px-4 fw-bold border-0 shadow-sm" data-bs-toggle="modal" data-bs-target="#addPlanModal"><i class="fa-solid fa-plus me-2"></i> Add New Stage</button>
                    </div>

                    <div class="timeline position-relative">
                        <% if(trip.planner && trip.planner.length > 0) { %>
                            <% trip.planner.forEach((stage, idx) => { %>
                                <div class="timeline-item position-relative ps-5 pb-5">
                                    <div class="timeline-dot position-absolute top-0 start-0 bg-primary rounded-circle border border-4 border-white shadow-sm" style="width: 24px; height: 24px; z-index: 1;"></div>
                                    <div class="card border-1 shadow-none rounded-4 p-4 hover-lift">
                                        <div class="row g-4">
                                            <div class="col-md-2 text-center text-md-start border-end pe-4">
                                                <h4 class="fw-900 mb-0 text-primary">Day <%= stage.day %></h4>
                                                <small class="text-muted fw-bold xsmall"><%= stage.date ? stage.date.toLocaleDateString() : 'Explore' %></small>
                                            </div>
                                            <div class="col-md-10 ps-md-5">
                                                <% stage.places.forEach(place => { %>
                                                    <div class="mb-3">
                                                        <h6 class="fw-bold mb-1"><%= place.name %></h6>
                                                        <p class="text-muted small mb-0"><%= place.notes || 'No notes for this landmark yet.' %></p>
                                                    </div>
                                                <% }) %>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            <% }) %>
                        <% } else { %>
                            <div class="text-center py-5">
                                <div class="bg-light p-4 rounded-circle d-inline-flex mb-4">
                                    <i class="fa-solid fa-map-marked-alt fs-1 text-muted opacity-25"></i>
                                </div>
                                <h6 class="fw-bold text-muted">A map without coordinates is just a picture. Start adding your destinations!</h6>
                                <button class="btn btn-primary rounded-pill px-4 fw-bold border-0 mt-3 shadow-none" data-bs-toggle="modal" data-bs-target="#addPlanModal">Mark My First Destination</button>
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Add Plan Modal -->
<div class="modal fade" id="addPlanModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-4 shadow-lg overflow-hidden">
            <div class="p-4 border-bottom bg-light bg-opacity-50 text-center">
                <h5 class="fw-bold mb-0">Record a Trip Landmark</h5>
            </div>
            <form action="/dashboard/trip/<%= tripId %>/planner/add" method="POST">
                <div class="modal-body p-4">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label fw-bold xsmall text-muted">TRIP DAY</label>
                            <input type="number" name="day" class="form-control rounded-pill py-3 px-4 shadow-none bg-light bg-opacity-50 xsmall" placeholder="Day 1" required>
                        </div>
                        <div class="col-md-8">
                            <label class="form-label fw-bold xsmall text-muted">DESTINATION / PLACE</label>
                            <input type="text" name="place" class="form-control rounded-pill py-3 px-4 shadow-none bg-light bg-opacity-50 xsmall" placeholder="Statue of Liberty" required>
                        </div>
                        <div class="col-md-12">
                            <label class="form-label fw-bold xsmall text-muted">NOTES (ACTIVITY / TIMING)</label>
                            <textarea name="notes" class="form-control rounded-4 py-3 px-4 shadow-none bg-light bg-opacity-50 xsmall" rows="3" placeholder="Visit early morning to avoid crowds..."></textarea>
                        </div>
                    </div>
                </div>
                <div class="p-4 border-top d-flex gap-2">
                    <button type="button" class="btn btn-light rounded-pill px-4 fw-bold flex-fill py-2" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary rounded-pill px-4 fw-bold flex-fill py-2">Add to Itinerary</button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .timeline::before {
        content: '';
        position: absolute;
        top: 0;
        bottom: 0;
        left: 12px;
        width: 1px;
        background: #e2e8f0;
    }
    .timeline-dot { left: 0 !important; transform: translateX(-50%); }
    .hover-lift { transition: transform 0.2s, box-shadow 0.2s; border: 1px solid #f1f5f9 !important; }
    .hover-lift:hover { transform: translateY(-3px); box-shadow: 0 5px 15px rgba(0,0,0,0.05) !important; border-color: #cbd5e1 !important; }
</style>
