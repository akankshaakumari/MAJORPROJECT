<% layout("/layouts/boilerplate") %>

<style>
    .reset-container {
        max-width: 460px;
        margin: 6rem auto;
    }
    .reset-card {
        border-radius: 1.5rem;
        border: 1px solid #ebebeb;
    }
    .input-icon {
        width: 48px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #717171;
    }
</style>

<div class="reset-container px-3">
    <div class="card reset-card shadow-sm">
        <div class="card-body p-4 p-md-5">
            <div class="text-center mb-5">
                <i class="fa-solid fa-lock-open fs-1 text-primary mb-3"></i>
                <h3 class="fw-bold mb-1">Set New Password</h3>
                <p class="text-secondary small">Your security is our priority. Choose a strong password.</p>
            </div>

            <form action="/reset-password" method="POST" class="needs-validation" novalidate>
                <input type="hidden" name="email" value="<%= email %>">
                <input type="hidden" name="otp" value="<%= otp %>">
                
                <div class="mb-4">
                    <label for="password" class="form-label fw-bold small text-secondary">NEW PASSWORD</label>
                    <div class="d-flex border rounded-3 bg-light bg-opacity-50 overflow-hidden shadow-sm">
                        <div class="input-icon bg-white"><i class="fa-solid fa-lock small"></i></div>
                        <input type="password" id="password" name="password" minlength="4" class="form-control border-0 bg-white py-3 shadow-none" placeholder="Enter new password" required>
                    </div>
                </div>

                <div class="mb-5">
                    <label for="confirmPassword" class="form-label fw-bold small text-secondary">CONFIRM PASSWORD</label>
                    <div class="d-flex border rounded-3 bg-light bg-opacity-50 overflow-hidden shadow-sm">
                        <div class="input-icon bg-white"><i class="fa-solid fa-lock small"></i></div>
                        <input type="password" id="confirmPassword" name="confirmPassword" minlength="4" class="form-control border-0 bg-white py-3 shadow-none" placeholder="Confirm new password" required>
                    </div>
                </div>

                <button type="submit" class="btn btn-lg w-100 text-white border-0 shadow-sm py-3" style="background: linear-gradient(135deg, #FF385C 0%, #BD1E59 100%); border-radius: 0.75rem; font-weight: 700; letter-spacing: 1px;">RESET PASSWORD</button>
            </form>
        </div>
    </div>
</div>
