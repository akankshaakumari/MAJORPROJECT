<% layout("/layouts/boilerplate") %>

<style>
    .login-container {
        max-width: 460px;
        margin: 4rem auto;
    }
    .role-selector {
        background: #f7f7f7;
        padding: 4px;
        border-radius: 2rem;
        display: flex;
        margin-bottom: 2.5rem;
    }
    .role-btn {
        flex: 1;
        padding: 0.6rem;
        border-radius: 2rem;
        border: none;
        background: transparent;
        font-weight: 700;
        font-size: 0.85rem;
        color: #717171;
        transition: 0.2s ease-in-out;
    }
    .role-btn.active {
        background: #ffffff;
        color: #fe424d;
        box-shadow: 0 4px 10px rgba(0,0,0,0.05);
    }
    .login-card {
        border-radius: 1.5rem;
        border: 1px solid #ebebeb;
    }
    .input-icon {
        width: 48px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #717171;
    }
</style>

<div class="login-container px-3">
    <div class="card login-card shadow-sm">
        <div class="card-body p-4 p-md-5">
            <div class="text-center mb-5">
                <i class="fa-solid fa-compass fs-1 text-primary mb-3"></i>
                <h3 class="fw-bold mb-1">Welcome Back</h3>
                <p class="text-secondary small">Login to your WanderLust account</p>
            </div>

            <div class="role-selector">
                <button class="role-btn active" onclick="toggleRole(this, 'Traveler')">Traveler</button>
                <button class="role-btn" onclick="toggleRole(this, 'Host')">Host</button>
                <button class="role-btn" onclick="toggleRole(this, 'Admin')">Admin</button>
            </div>

            <form action="/login" method="POST" class="needs-validation" novalidate>
                <div class="mb-4">
                    <label for="username" class="form-label fw-bold small text-secondary">USERNAME</label>
                    <div class="d-flex border rounded-3 bg-light bg-opacity-50 overflow-hidden shadow-sm">
                        <div class="input-icon bg-white"><i class="fa-solid fa-user-circle small"></i></div>
                        <input type="text" id="username" name="username" class="form-control border-0 bg-white py-3 shadow-none" placeholder="Username" required>
                    </div>
                    <div class="invalid-feedback">Please enter your username.</div>
                </div>

                <div class="mb-5">
                    <div class="d-flex justify-content-between align-items-center">
                        <label for="password" class="form-label fw-bold small text-secondary">PASSWORD</label>
                        <a href="/forgot-password" class="text-decoration-none text-muted xsmall fw-bold">Forgot?</a>
                    </div>
                    <div class="d-flex border rounded-3 bg-light bg-opacity-50 overflow-hidden shadow-sm">
                        <div class="input-icon bg-white"><i class="fa-solid fa-lock small"></i></div>
                        <input type="password" id="password" name="password" class="form-control border-0 bg-white py-3 shadow-none" placeholder="Password" required>
                    </div>
                    <div class="invalid-feedback">Please enter your password.</div>
                </div>

                <button type="submit" id="loginBtn" class="btn btn-lg w-100 text-white border-0 shadow-sm py-3" style="background: linear-gradient(135deg, #FF385C 0%, #BD1E59 100%); border-radius: 0.75rem; font-weight: 700; letter-spacing: 1px;">LOG IN</button>

                <p class="text-center mt-4 text-muted small">New to WanderLust? <a href="/signup" class="text-primary text-decoration-none fw-bold">Create account</a></p>
            </form>
        </div>
    </div>
</div>

<script>
    function toggleRole(btn, role) {
        document.querySelectorAll('.role-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        
        const loginBtn = document.getElementById('loginBtn');
        if(role === 'Admin') {
            loginBtn.style.background = 'linear-gradient(135deg, #222222 0%, #444444 100%)';
            loginBtn.innerHTML = '<i class="fa-solid fa-shield-halved me-2"></i> ADMIN LOGIN';
        } else if(role === 'Host') {
            loginBtn.style.background = 'linear-gradient(135deg, #FF385C 0%, #BD1E59 100%)';
            loginBtn.innerHTML = 'HOST LOGIN';
        } else {
            loginBtn.style.background = 'linear-gradient(135deg, #FF385C 0%, #BD1E59 100%)';
            loginBtn.innerHTML = 'LOG IN';
        }
    }
</script>
