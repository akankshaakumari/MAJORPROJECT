<% layout("/layouts/boilerplate") %>

<style>
    .forgot-container {
        max-width: 460px;
        margin: 6rem auto;
    }
    .forgot-card {
        border-radius: 1.5rem;
        border: 1px solid #ebebeb;
    }
    .input-icon {
        width: 48px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #717171;
    }
</style>

<div class="forgot-container px-3">
    <div class="card forgot-card shadow-sm">
        <div class="card-body p-4 p-md-5">
            <div class="text-center mb-5">
                <i class="fa-solid fa-key fs-1 text-primary mb-3"></i>
                <h3 class="fw-bold mb-1">Forgot Password?</h3>
                <p class="text-secondary small">Enter your email to receive a recovery OTP.</p>
            </div>

            <form action="/forgot-password" method="POST" class="needs-validation" novalidate>
                <div class="mb-5">
                    <label for="email" class="form-label fw-bold small text-secondary">EMAIL ADDRESS</label>
                    <div class="d-flex border rounded-3 bg-light bg-opacity-50 overflow-hidden shadow-sm">
                        <div class="input-icon bg-white"><i class="fa-solid fa-envelope small"></i></div>
                        <input type="email" id="email" name="email" class="form-control border-0 bg-white py-3 shadow-none" placeholder="example@wanderlust.com" required>
                    </div>
                </div>

                <button type="submit" class="btn btn-lg w-100 text-white border-0 shadow-sm py-3" style="background: linear-gradient(135deg, #FF385C 0%, #BD1E59 100%); border-radius: 0.75rem; font-weight: 700; letter-spacing: 1px;">SEND OTP</button>

                <p class="text-center mt-4 text-muted small">Remembered? <a href="/login" class="text-primary text-decoration-none fw-bold">Back to Login</a></p>
            </form>
        </div>
    </div>
</div>
